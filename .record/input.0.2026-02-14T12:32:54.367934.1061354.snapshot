[872.222873, "o", "(B\u001b[m\u001b[38;2;11;83;101m\u001b[48;2;0;43;54mâ”†\u001b[15;18H\u001b(B\u001b[m\u001b[38;2;131;148;150m\u001b[48;2;0;43;54m \u001b(B\u001b[m\u001b[38;2;11;83;101m\u001b[48;2;0;43;54mâ”†\u001b[15;20H\u001b(B\u001b[m\u001b[38;2;131;148;150m\u001b[48;2;0;43;54m \u001b(B\u001b[m\u001b[38;2;11;83;101m\u001b[48;2;0;43;54mâ”†\u001b[15;22H\u001b(B\u001b[m\u001b[38;2;131;148;150m\u001b[48;2;0;43;54m  \u001b(B\u001b[m\u001b[3m\u001b[38;2;88;110;117m\u001b[48;2;0;43;54m// existing\r\n\u001b(B\u001b[m\u001b[38;2;88;110;117m\u001b[48;2;7;54;66m141 \u001b(B\u001b[m\u001b[38;2;147;161;161m\u001b[48;2;0;43;54mâ”†\u001b[16;6H\u001b(B\u001b[m\u001b[38;2;131;148;150m\u001b[48;2;0;43;54m \u001b(B\u001b[m\u001b[38;2;205;102;0m\u001b[48;2;0;43;54m}\r\n\u001b(B\u001b[m\u001b[38;2;88;110;117m\u001b[48;2;7;54;66m142 \u001b(B\u001b[m\u001b[38;2;147;161;161m\u001b[48;2;0;43;54mâ”†\u001b[18;1H\u001b(B\u001b[m\u001b[38;2;88;110;117m\u001b[48;2;7;54;66m143 \u001b(B\u001b[m\u001b[38;2;147;161;161m\u001b[48;2;0;43;54mâ”†\u001b[18;6H\u001b(B\u001b[m\u001b[38;2;131;148;150m\u001b[48;2;0;43;54m \u001b(B\u001b[m\u001b[3m\u001b[38;2;88;110;117m\u001b[48;2;0;43;54m// okay, now block is prev both have something on them, as break was activated\r\n\u001b(B\u001b[m\u001b[38;2;88;110;117m\u001b[48;2;7;54;66m144 \u001b(B\u001b[m\u001b[38;2;147;161;161m\u001b[48;2;0;43;54mâ”†\u001b[19;6H\u001b(B\u001b[m\u001b[38;2;131;148;150m\u001b[48;2;0;43;54m \u001b(B\u001b[m\u001b[3m\u001b[38;2;88;110;117m\u001b[48;2;0;43;54m// when I break a block up, we get total size, and another header\r\n\u001b(B\u001b[m\u001b[38;2;88;110;117m\u001b[48;2;7;54;66m145 \u001b(B\u001b[m\u001b[38;2;147;161;161m\u001b[48;2;0;43;54mâ”†\u001b[20;6H\u001b(B\u001b[m\u001b[38;2;131;148;150m\u001b[48;2;0;43;54m \u001b(B\u001b[m\u001b[3m\u001b[38;2;88;110;117m\u001b[48;2;0;43;54m// as such, size i need is totalSize + sizeof(struct header) why isn't there a typedef?\r\n\u001b(B\u001b[m\u001b[38;2;88;110;117m\u001b[48;2;7;54